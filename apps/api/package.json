{
    "name": "@tms/api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:seed": "tsx src/db/seed.ts",
        "auth:reset-password": "tsx scripts/reset-password.ts"
    },
    "dependencies": {
        "@casl/ability": "^6.7.0",
        "@fastify/cookie": "^11.0.0",
        "@fastify/cors": "^11.0.0",
        "@fastify/helmet": "^13.0.0",
        "@fastify/jwt": "^9.0.0",
        "@fastify/multipart": "^9.0.0",
        "@fastify/rate-limit": "^10.0.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "@fastify/websocket": "^11.2.0",
        "@tms/shared": "workspace:*",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.0.0",
        "drizzle-orm": "^0.38.0",
        "fast-xml-parser": "^5.4.2",
        "fastify": "^5.2.0",
        "ioredis": "^5.4.0",
        "nanoid": "^5.0.0",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.0",
        "@types/node": "^22.0.0",
        "drizzle-kit": "^0.30.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.18"
    }
}
