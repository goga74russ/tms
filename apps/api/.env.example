# ============================================================
# TMS API — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://tms:tms@localhost:5433/tms

# Auth
JWT_SECRET=tms-dev-secret-change-in-production

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Redis (для BullMQ)
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=  # Uncomment for production

# Seed (for db:seed command — password for all test users)
SEED_PASSWORD=demo123
