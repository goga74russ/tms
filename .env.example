# ============================================================
# TMS Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- Database ---
POSTGRES_DB=tms
POSTGRES_USER=tms
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tms:change-me-in-production@postgres:5432/tms

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- API Server ---
API_PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Auth (REQUIRED) ---
JWT_SECRET=generate-a-secure-random-string-here

# --- CORS ---
# Comma-separated origins for production
CORS_ORIGIN=https://tms.example.com

# --- Web Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://tms.example.com/api

# --- Integrations (optional) ---
# WIALON_TOKEN=
# DADATA_API_KEY=
# FUEL_CARD_API_KEY=
# SENTRY_DSN=

# --- S3/MinIO (Sprint 6) ---
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=tms-files
