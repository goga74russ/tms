# ============================================================
# TMS Environment Variables — Production
# Copy to .env and fill in ALL required values
# ============================================================

# --- Database (REQUIRED) ---
POSTGRES_DB=tms
POSTGRES_USER=tms
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://tms:CHANGE_ME_STRONG_PASSWORD@postgres:5432/tms

# --- Redis (REQUIRED) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- API Server ---
API_PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Auth (REQUIRED) ---
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# --- CORS ---
# Comma-separated origins for production
CORS_ORIGIN=https://tms.example.com

# --- Web Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://tms.example.com/api

# --- Integrations (optional) ---
# WIALON_TOKEN=
# DADATA_API_KEY=
# FUEL_CARD_API_KEY=
# SENTRY_DSN=

# --- S3/MinIO (Sprint 6) ---
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=tms-files
