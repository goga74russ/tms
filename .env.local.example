# ============================================================
# TMS Environment Variables — Local Development
# Copy to .env and use as-is for local dev with docker-compose.yml
# ============================================================

# --- Application ---
APP_TIMEZONE=Europe/Moscow

# --- Database (local compose) ---
POSTGRES_DB=tms
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms_dev_2026
DATABASE_URL=postgresql://tms:tms_dev_2026@localhost:5433/tms

# --- Redis (local compose, password synced with docker-compose.yml) ---
REDIS_PASSWORD=redis_dev_2026
REDIS_URL=redis://:redis_dev_2026@localhost:6379

# --- API Server ---
API_PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug

# --- Auth ---
JWT_SECRET=dev-secret-do-not-use-in-production-12345

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Web Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# --- Telegram Bot (Sprint 6) ---
# Create bot via @BotFather, get token
TELEGRAM_BOT_TOKEN=
